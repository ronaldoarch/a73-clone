            },
            "url": "{{API_URL}}"
          }
        },
        {
          "name": "Get Game List",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"method\": \"game_list\",\n  \"agent_code\": \"{{agent_code}}\",\n  \"agent_token\": \"{{agent_token}}\",\n  \"provider_code\": \"PRAGMATIC\"\n}"
            },
            "url": "{{API_URL}}"
          }
        }
      ]
    },
    {
      "name": "6. History",
      "item": [
        {
          "name": "Get Game History",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"method\": \"get_game_log\",\n  \"agent_code\": \"{{agent_code}}\",\n  \"agent_token\": \"{{agent_token}}\",\n  \"user_code\": \"{{user_code}}\",\n  \"game_type\": \"slot\",\n  \"start\": \"2022-09-29 00:00:00\",\n  \"end\": \"2022-09-30 23:59:00\",\n  \"page\": 0,\n  \"perPage\": 1000\n}"
            },
            "url": "{{API_URL}}"
