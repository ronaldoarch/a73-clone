{
  "name": "a73-clone",
  "version": "1.0.0",
  "description": "Réplica editável do A73 - Vue 3 + Ionic",
  "type": "module",
  "overrides": {
    "rollup": "npm:@rollup/wasm-node@latest"
  },
  "pnpm": {
    "overrides": {
      "rollup": "npm:@rollup/wasm-node@latest"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "postgres:up": "docker compose -f docker-compose.dev.yml up -d",
    "postgres:down": "docker compose -f docker-compose.dev.yml down",
    "db:push": "cd backend && npx prisma db push"
  },
  "dependencies": {
    "@ionic/vue": "^7.0.0",
    "@ionic/vue-router": "^7.0.0",
    "ionicons": "^7.1.0",
    "qrcode": "^1.5.4",
    "swiper": "^12.1.2",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.0",
    "vite-plugin-pwa": "^1.2.0"
  }
}
