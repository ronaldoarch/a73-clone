# ─── Base de dados (MySQL) ───
# O Prisma está configurado para MySQL (produção Coolify, serviço MySQL da stack).
# Formato: mysql://UTILIZADOR:PALAVRA-PASSE@HOST:PORTA/NOME_BD
# Exemplo interno Docker: mysql://app:secret@mysql:3306/a73
#
# Desenvolvimento local: suba um MySQL (Docker: mysql:8) e aponte para ele.
# Não use postgresql:// nem file: — o provider do schema é mysql.

DATABASE_URL="mysql://root:password@127.0.0.1:3306/a73_dev"

# JWT - gere um segredo forte em produção
JWT_SECRET="a73-secret-change-in-production"

PORT=3000

# Servir site_baixado (admin + legado) quando o Vue não estiver em frontend/dist
SERVE_SITE_BAIXADO=1

# URL pública do site (CORS)
FRONTEND_URL="https://seudominio.com"

# iGameWin Seamless
# IGAMEWIN_AGENT_CODE=""
# IGAMEWIN_AGENT_SECRET=""

# GATEBOX_WEBHOOK_TOKEN=""
# CYBER_WEBHOOK_SECRET=""
