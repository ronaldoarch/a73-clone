# PostgreSQL
# Local (docker-compose.dev): postgresql://a73:a73@localhost:5432/a73db
# Coolify: use a DATABASE_URL fornecida
DATABASE_URL="postgresql://a73:a73@localhost:5432/a73db"

# JWT - gere um segredo forte em produção
JWT_SECRET="a73-secret-change-in-production"

# Porta do servidor
PORT=3000

# iGameWin Seamless (Site API) - obrigatório para modo Seamless
# IGAMEWIN_AGENT_CODE="Midaslabs"
# IGAMEWIN_AGENT_SECRET="seu-agent-secret"

# Token de verificação do webhook Gatebox (opcional mas recomendado)
# Configure o mesmo valor no painel Gatebox em "Webhook Secret/Token"
# GATEBOX_WEBHOOK_TOKEN="token-secreto-aqui"
