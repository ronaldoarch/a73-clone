# PostgreSQL
# Local (Docker): postgresql://a73:a73@localhost:5432/a73db
# Online (dev sem Docker):
#   Neon (gratuito): https://neon.tech - crie projeto, copie connection string
#   Supabase (gratuito): https://supabase.com - Project Settings > Database > Connection string
# Exemplo Neon: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://a73:a73@localhost:5432/a73db"

# JWT - gere um segredo forte em produção
JWT_SECRET="a73-secret-change-in-production"

# Porta do servidor
PORT=3000

# Servir o clone estático ../site_baixado na mesma porta (UI + API). Use 0 para desligar.
SERVE_SITE_BAIXADO=1

# iGameWin Seamless (Site API) - obrigatório para modo Seamless
# IGAMEWIN_AGENT_CODE="Midaslabs"
# IGAMEWIN_AGENT_SECRET="seu-agent-secret"

# Token de verificação do webhook Gatebox (opcional mas recomendado)
# Configure o mesmo valor no painel Gatebox em "Webhook Secret/Token"
# GATEBOX_WEBHOOK_TOKEN="token-secreto-aqui"
