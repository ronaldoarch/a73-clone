            },
            "url": "{{API_URL}}"
          }
        },
        {
          "name": "Launch Game (Evolution)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"method\": \"game_launch\",\n  \"agent_code\": \"{{agent_code}}\",\n  \"agent_token\": \"{{agent_token}}\",\n  \"user_code\": \"{{user_code}}\",\n  \"provider_code\": \"EVOLUTION\",\n  \"game_code\": \"nxpkul2hgclallno\",\n  \"lang\": \"en\"\n}"
            },
            "url": "{{API_URL}}"
          }
        }
      ]
    },
    {
      "name": "5. Catalog",
      "item": [
        {
          "name": "Get Provider List",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
